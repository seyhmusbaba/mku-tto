# Veritabanı (Railway PostgreSQL eklentisi otomatik sağlar)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT
JWT_SECRET=cok-gizli-bir-anahtar-buraya-yazin
JWT_EXPIRES_IN=7d

# Uygulama
PORT=3001
NODE_ENV=production

# YZ özelliği (isteğe bağlı)
ANTHROPIC_API_KEY=sk-ant-...

# Scopus entegrasyonu (isteğe bağlı)
# API Key: dev.elsevier.com adresinden alınır
# Inst Token: apisupport@elsevier.com adresinden talep edilir
SCOPUS_API_KEY=
SCOPUS_INST_TOKEN=
